---
const year = new Date().getFullYear();
---
<footer class="border-t border-surface-200 bg-surface-50 py-12 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <!-- Brand -->
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-lg bg-brand-500 flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <span class="text-sm font-extrabold text-surface-900 font-display">Pactly</span>
      </div>

      <!-- Tagline -->
      <p class="text-sm text-surface-800/50 italic font-display">Build habits. Keep promises. Together.</p>

      <!-- Links + copyright -->
      <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6 text-sm text-surface-800/50">
        <a href="mailto:hello@pactly.app" class="hover:text-surface-900 transition-colors">hello@pactly.app</a>
        <span class="hidden sm:inline">·</span>
        <a href="/privacy" class="hover:text-surface-900 transition-colors">Privacy</a>
        <span class="hidden sm:inline">·</span>
        <span>&copy; {year} Pactly. All rights reserved.</span>
      </div>
    </div>
  </div>
</footer>
