    <!-- Nav links -->
    <div class="hidden sm:flex items-center gap-7">
      <a href="#features" class="text-sm font-medium text-surface-800/60 hover:text-surface-900 transition-colors">Features</a>
      <a href="#how-it-works" class="text-sm font-medium text-surface-800/60 hover:text-surface-900 transition-colors">How it works</a>
