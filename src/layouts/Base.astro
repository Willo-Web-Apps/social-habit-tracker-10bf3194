---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Pactly — Build habits. Keep promises. Together.",
  description = "Pactly turns your real friendships into an accountability system — track habits together, celebrate streaks, and never break a promise alone."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Pactly",
      "description": "Pactly turns your real friendships into an accountability system — track habits together, celebrate streaks, and never break a promise alone.",
      "url": "https://social-habit-tracker.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
