---
import Base from '../layouts/Base.astro';
---
<Base
  title="Pactly — Build habits. Keep promises. Together."
  description="Pactly turns your real friendships into an accountability system — track habits together, celebrate streaks, and never break a promise alone."
>

  <!-- ============================================================
       HERO — full-width, layered gradient, bold serif headline
       ============================================================ -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">
    <!-- Layered CSS background: warm cream with coral and green orbs -->
    <div
      class="absolute inset-0"
      style="background:
        radial-gradient(ellipse at 15% 60%, oklch(0.63 0.19 35 / 0.12), transparent 45%),
        radial-gradient(ellipse at 85% 20%, oklch(0.40 0.09 155 / 0.08), transparent 40%),
        radial-gradient(ellipse at 60% 85%, oklch(0.72 0.16 35 / 0.07), transparent 35%),
        linear-gradient(160deg, oklch(0.985 0.008 70) 0%, oklch(0.96 0.010 70) 100%);"
    ></div>

    <!-- Decorative floating rings -->
    <div class="absolute top-20 right-12 w-72 h-72 rounded-full border border-brand-200 opacity-40 animate-float" style="animation-delay:0s;"></div>
    <div class="absolute bottom-16 left-8 w-48 h-48 rounded-full border border-accent-100 opacity-30 animate-float" style="animation-delay:2s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <p class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-widest text-brand-500 animate-slide-up mb-6">
          <span class="w-5 h-0.5 bg-brand-500 inline-block"></span>
          Social accountability, reimagined
        </p>

        <!-- H1 — seed headline verbatim -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-surface-900 font-display leading-[1.05] animate-slide-up delay-100">
          The habit tracker your<br/>
          <em class="italic font-light text-brand-500 not-italic" style="font-style:italic;">friends</em> can actually see
        </h1>

        <!-- Sub — seed hero_sub verbatim -->
        <p class="mt-7 text-lg md:text-xl text-surface-800/70 max-w-2xl leading-relaxed animate-slide-up delay-200 font-body">
          Pactly turns your real friendships into an accountability system — track habits together, celebrate streaks, and never break a promise alone.
        </p>

        <!-- CTA row -->
        <div class="mt-10 flex flex-col sm:flex-row items-start sm:items-center gap-4 animate-slide-up delay-300">
          <a
            href="#cta"
            class="inline-block px-8 py-4 bg-brand-500 text-white font-semibold rounded-xl hover:bg-brand-600 transition-colors text-base shadow-lg shadow-brand-500/25"
          >
            Start my first pact →
          </a>
          <a href="#how-it-works" class="text-sm font-medium text-surface-800/60 hover:text-surface-900 transition-colors underline underline-offset-4">
            See how it works
          </a>
        </div>

        <!-- Micro-proof -->
        <p class="mt-5 text-sm text-surface-800/40 animate-slide-up delay-400">
          Free to start &nbsp;·&nbsp; No credit card required &nbsp;·&nbsp; Works on iOS &amp; Android
        </p>
      </div>

      <!-- Hero visual — mock habit card, right side, desktop only -->
      <div class="hidden lg:block absolute right-8 top-1/2 -translate-y-1/2 w-80 animate-slide-up delay-400">
        <div class="bg-white rounded-2xl shadow-2xl shadow-surface-900/10 p-6 border border-surface-200">
          <div class="flex items-center justify-between mb-5">
            <span class="text-sm font-semibold text-surface-900">This week's pact</span>
            <span class="text-xs bg-accent-100 text-accent-600 px-2.5 py-1 rounded-full font-semibold">4 friends active</span>
          </div>
          <!-- Habit rows -->
          {[
            { name: "Morning run", emoji: "🏃", days: [1,1,1,1,0,0,0] },
            { name: "No alcohol", emoji: "🧃", days: [1,1,1,1,1,0,0] },
            { name: "Read 20 min", emoji: "📖", days: [1,0,1,1,1,0,0] },
          ].map(h => (
            <div class="mb-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-base">{h.emoji}</span>
                <span class="text-sm font-medium text-surface-900">{h.name}</span>
              </div>
              <div class="flex gap-1">
                {h.days.map((done, i) => (
                  <div
                    class={`w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold ${done ? 'bg-brand-500 text-white' : 'bg-surface-100 text-surface-300'}`}
                  >
                    {done ? '✓' : ['M','T','W','T','F','S','S'][i]}
                  </div>
                ))}
              </div>
            </div>
          ))}
          <!-- Friend avatars -->
          <div class="mt-5 pt-4 border-t border-surface-100 flex items-center gap-1.5">
            {['🧑','👩','🧔','👧'].map((e, i) => (
              <div class={`w-8 h-8 rounded-full bg-surface-200 flex items-center justify-center text-sm border-2 border-white ${i > 0 ? '-ml-2' : ''}`}>
                {e}
              </div>
            ))}
            <span class="ml-2 text-xs text-surface-800/50 font-medium">All checked in today</span>
          </div>
        </div>
        <!-- Floating notification -->
        <div class="mt-3 ml-6 bg-white rounded-xl shadow-lg shadow-surface-900/8 border border-surface-200 px-4 py-3 flex items-center gap-3 animate-float">
          <span class="text-lg">🎉</span>
          <div>
            <p class="text-xs font-semibold text-surface-900">Alex kept their streak!</p>
            <p class="text-xs text-surface-800/50">7 days · Morning run</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       SOCIAL PROOF BAR
       ============================================================ -->
  <section class="bg-accent-500 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { stat: "83%", label: "of Pactly users hit their 30-day goal" },
          { stat: "4.2×", label: "more consistent with an accountability partner" },
          { stat: "12k+", label: "active pacts running right now" },
          { stat: "2.1M", label: "habits checked in and counting" },
        ].map(item => (
          <div class="animate-slide-up">
            <p class="text-3xl md:text-4xl font-extrabold text-white font-display">{item.stat}</p>
            <p class="mt-1.5 text-sm text-white/70 leading-snug max-w-[150px] mx-auto">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ============================================================
       FEATURES GRID — 4 cards
       ============================================================ -->
  <section id="features" class="py-20 md:py-28 lg:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="max-w-2xl mb-16 animate-slide-up">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-500 mb-3">Why Pactly works</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900 font-display">
          Willpower runs out.<br/>
          <span class="text-brand-500">Friendship doesn't.</span>
        </h2>
        <p class="mt-4 text-lg text-surface-800/60 leading-relaxed">
          Pactly is built for people who already know what they want — they just need someone in their corner on a Tuesday at 7am.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Feature 1 -->
        <div class="bg-white rounded-2xl p-7 border border-surface-200 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-200 animate-slide-up delay-100">
          <div class="w-11 h-11 bg-brand-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-surface-900 mb-2 font-display">Real friends, real stakes</h3>
          <p class="text-sm text-surface-800/60 leading-relaxed">
            Invite the people who already know your goals. Your actual friends — not anonymous strangers on a leaderboard.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-white rounded-2xl p-7 border border-surface-200 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-200 animate-slide-up delay-200">
          <div class="w-11 h-11 bg-brand-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-surface-900 mb-2 font-display">Transparent check-ins</h3>
          <p class="text-sm text-surface-800/60 leading-relaxed">
            Everyone in your pact sees who checked in — and who didn't. That gentle visibility is often all the push you need.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-white rounded-2xl p-7 border border-surface-200 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-200 animate-slide-up delay-300">
          <div class="w-11 h-11 bg-brand-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-surface-900 mb-2 font-display">Streak tracking that matters</h3>
          <p class="text-sm text-surface-800/60 leading-relaxed">
            Track personal streaks alongside your group's momentum. Celebrate together when someone hits 7, 30, or 100 days.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="bg-white rounded-2xl p-7 border border-surface-200 hover:border-brand-200 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-200 animate-slide-up delay-400">
          <div class="w-11 h-11 bg-accent-100 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <h3 class="text-base font-bold text-surface-900 mb-2 font-display">Built-in encouragement</h3>
          <p class="text-sm text-surface-800/60 leading-relaxed">
            Send a quick cheer, call someone out kindly, or share a win. Connection is baked into every check-in — not an afterthought.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       HOW IT WORKS — 3 steps
       ============================================================ -->
  <section id="how-it-works" class="py-20 md:py-28 lg:py-32 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 animate-slide-up">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-500 mb-3">Getting started</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900 font-display">
          From solo struggle to shared momentum — in 3 steps
        </h2>
      </div>

      <div class="relative">
        <!-- Connector line (desktop) -->
        <div class="hidden md:block absolute top-10 left-1/2 -translate-x-1/2 w-2/3 h-0.5 bg-surface-200"></div>

        <div class="grid md:grid-cols-3 gap-10 md:gap-8 relative">
          <!-- Step 1 -->
          <div class="text-center animate-slide-up delay-100">
            <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-brand-500 flex items-center justify-center shadow-lg shadow-brand-500/30 relative">
              <span class="text-3xl font-extrabold text-white font-display">1</span>
            </div>
            <h3 class="text-xl font-bold text-surface-900 mb-3 font-display">Create a pact</h3>
            <p class="text-surface-800/60 leading-relaxed text-sm max-w-xs mx-auto">
              Name your habit, set the frequency — daily, 5x a week, weekdays only — and decide how long your pact runs.
            </p>
          </div>

          <!-- Step 2 -->
          <div class="text-center animate-slide-up delay-200">
            <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-brand-500 flex items-center justify-center shadow-lg shadow-brand-500/30 relative">
              <span class="text-3xl font-extrabold text-white font-display">2</span>
            </div>
            <h3 class="text-xl font-bold text-surface-900 mb-3 font-display">Invite your people</h3>
            <p class="text-surface-800/60 leading-relaxed text-sm max-w-xs mx-auto">
              Share a link with 1–10 friends. They join in seconds — no new account needed if they already have Pactly.
            </p>
          </div>

          <!-- Step 3 -->
          <div class="text-center animate-slide-up delay-300">
            <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-accent-500 flex items-center justify-center shadow-lg shadow-accent-500/20 relative">
              <span class="text-3xl font-extrabold text-white font-display">3</span>
            </div>
            <h3 class="text-xl font-bold text-surface-900 mb-3 font-display">Check in daily</h3>
            <p class="text-surface-800/60 leading-relaxed text-sm max-w-xs mx-auto">
              One tap to log your habit. See your friends' check-ins roll in. Celebrate wins, learn from misses — together.
            </p>
          </div>
        </div>
      </div>

      <!-- Callout block -->
      <div class="mt-16 bg-white rounded-2xl border border-surface-200 p-8 md:p-10 flex flex-col md:flex-row items-center gap-6 animate-slide-up delay-400">
        <div class="w-14 h-14 shrink-0 rounded-full bg-brand-100 flex items-center justify-center text-2xl">
          📖
        </div>
        <div>
          <p class="text-sm font-semibold text-surface-900 mb-1">Read Atomic Habits?</p>
          <p class="text-surface-800/60 text-sm leading-relaxed">
            James Clear says accountability partners are the single most powerful external motivator for habit formation.
            Pactly makes that easy — no awkward texts to your gym buddy, no complicated spreadsheets.
            Just a shared feed that says <em class="text-surface-900 font-medium not-italic">"we're all in this."</em>
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       TESTIMONIALS / VOICE OF CUSTOMER
       ============================================================ -->
  <section class="py-20 md:py-28 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 animate-slide-up">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-500 mb-3">What people are saying</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900 font-display">
          Habits that actually stuck
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Quote 1 -->
        <div class="bg-white rounded-2xl p-7 border border-surface-200 animate-slide-up delay-100">
          <div class="flex items-center gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-surface-900 text-sm leading-relaxed mb-5 font-medium">
            "I've tried every habit app. They all fell apart after two weeks because no one knew I quit.
            With Pactly, my college friends see my streak every morning. I'm not letting them down."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-brand-100 flex items-center justify-center text-sm">🧑</div>
            <div>
              <p class="text-sm font-semibold text-surface-900">Marcus T.</p>
              <p class="text-xs text-surface-800/50">Software engineer, 31</p>
            </div>
          </div>
        </div>

        <!-- Quote 2 -->
        <div class="bg-white rounded-2xl p-7 border border-surface-200 animate-slide-up delay-200">
          <div class="flex items-center gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-surface-900 text-sm leading-relaxed mb-5 font-medium">
            "My sister and I started a 'no sugar weekdays' pact in January. It's July. We're still going.
            Neither of us would've lasted past February on our own."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-accent-100 flex items-center justify-center text-sm">👩</div>
            <div>
              <p class="text-sm font-semibold text-surface-900">Priya K.</p>
              <p class="text-xs text-surface-800/50">Marketing lead, 27</p>
            </div>
          </div>
        </div>

        <!-- Quote 3 -->
        <div class="bg-white rounded-2xl p-7 border border-surface-200 animate-slide-up delay-300">
          <div class="flex items-center gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-surface-900 text-sm leading-relaxed mb-5 font-medium">
            "We use it at work for a 'move for 20 minutes' pact. Sounds small, but our whole team feels the difference.
            It's weirdly become one of the best things we do together."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-brand-100 flex items-center justify-center text-sm">🧔</div>
            <div>
              <p class="text-sm font-semibold text-surface-900">David R.</p>
              <p class="text-xs text-surface-800/50">Team lead, 34</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       FINAL CTA — full-width accent gradient
       ============================================================ -->
  <section id="cta" class="py-20 md:py-28 relative overflow-hidden">
    <!-- Layered warm gradient background -->
    <div
      class="absolute inset-0"
      style="background:
        radial-gradient(ellipse at 70% 30%, oklch(0.72 0.16 35 / 0.35), transparent 55%),
        radial-gradient(ellipse at 20% 80%, oklch(0.40 0.09 155 / 0.20), transparent 50%),
        linear-gradient(135deg, oklch(0.63 0.19 35) 0%, oklch(0.54 0.19 35) 100%);"
    ></div>

    <!-- Decorative circles -->
    <div class="absolute -top-10 -right-10 w-64 h-64 rounded-full bg-white/5"></div>
    <div class="absolute -bottom-16 -left-8 w-80 h-80 rounded-full bg-white/5"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white font-display leading-tight animate-slide-up">
        Your friends are waiting.<br/>
        <span class="font-light italic">Make the pact.</span>
      </h2>
      <p class="mt-6 text-lg text-white/75 max-w-xl mx-auto leading-relaxed animate-slide-up delay-100">
        Stop relying on streaks and app notifications. Start relying on the people who actually care whether you show up.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up delay-200">
        <a
          href="mailto:hello@pactly.app"
          class="inline-block px-9 py-4 bg-white text-surface-900 font-bold rounded-xl hover:bg-surface-100 transition-colors text-base shadow-xl shadow-surface-900/20"
        >
          Start my first pact — it's free
        </a>
      </div>
      <p class="mt-4 text-sm text-white/50 animate-slide-up delay-300">
        No credit card. No subscription traps. Just accountability.
      </p>

      <!-- Mini trust badges -->
      <div class="mt-12 flex flex-wrap items-center justify-center gap-6 animate-slide-up delay-400">
        {[
          { icon: "🔒", label: "Private by default" },
          { icon: "📱", label: "iOS & Android" },
          { icon: "🌱", label: "Free tier forever" },
        ].map(badge => (
          <div class="flex items-center gap-2 text-white/60 text-sm">
            <span class="text-base">{badge.icon}</span>
            <span>{badge.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
